  <body>
<!-- Default translations -->
    <tu>
      <tuv lang="de-DE">
        <seg>(parts per million)&lt;x2/&gt;Teilchen in Millionen</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T114324Z" creationid="amando" creationdate="20260618T114324Z">
        <seg>(parts per million)&lt;x2/&gt;deeltjes per miljoen</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>&lt;x2/&gt;Starte den Simulator und beschreibe, was im Simulator passiert.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133235Z" creationid="amando" creationdate="20260618T133235Z">
        <seg>&lt;x2/&gt;Start de simulator en beschrijf wat er in de simulator gebeurt.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Abfragen&lt;x1/&gt;(ein-/zweifach)</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133051Z" creationid="amando" creationdate="20260618T133051Z">
        <seg>Vragen&lt;x1/&gt;(enkelvoudig/dubbel)</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Abfragen&lt;x1/&gt;(mehrfach)</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133059Z" creationid="amando" creationdate="20260618T133059Z">
        <seg>Zoekopdrachten&lt;x1/&gt;(meerdere)</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Alle 25 LEDs können rot leuchten.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133406Z" creationid="amando" creationdate="20260618T133406Z">
        <seg>Alle 25 LED's kunnen rood oplichten.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Anstecken und Luftqualität messen!</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T113610Z" creationid="amando" creationdate="20260618T113610Z">
        <seg>Aansluiten en de luchtkwaliteit meten!</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Anweisungen</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T114414Z" creationid="amando" creationdate="20260618T114414Z">
        <seg>Instructies</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Bausteine eines Computers</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T113534Z" creationid="amando" creationdate="20260618T113534Z">
        <seg>Onderdelen van een computer</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Beim Start erscheint ein Herz auf der LED-Matrix.&lt;x2/&gt;Lasse „Ich liebe Berlin!“ über die LED-Matrix laufen.&lt;x3/&gt;Lasse dauerhaft ein Herz auf der LED-Matrix blinken.&lt;x4/&gt;Tipp:&lt;x5/&gt; Tippe Dauerhaft in die Suche ein!&lt;x6/&gt;Lasse eine Rakete auf der LED-Matrix steigen.&lt;x7/&gt;Tipp:&lt;x8/&gt; Jetzt musst du denken, wie ein Trickfilmprofi&lt;x9/&gt;-  in Einzelbildern!&lt;x10/&gt;Bring die Programmblöcke in die richtige Reihenfolge&lt;x11/&gt;und lass einen Countdown von 3-2-1-0 anzeigen.&lt;x12/&gt;a) Füge hinter jeder Zahl eine &lt;x13/&gt;Pause&lt;x14/&gt; ein.&lt;x15/&gt;b) &lt;x16/&gt;Verlängere&lt;x17/&gt; die Pausen indem du den Wert der Millisekunden (MS) erhöhst.&lt;x18/&gt;c) &lt;x19/&gt;Speichere&lt;x20/&gt; dein Programm unter dem Namen „Raketenstart“.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133431Z" creationid="amando" creationdate="20260618T133427Z">
        <seg>Bij het opstarten verschijnt er een hart op de LED-matrix.&lt;x2/&gt;Laat „Ik hou van Berlijn!“ over de LED-matrix lopen.&lt;x3/&gt;Laat een hart continu op de LED-matrix knipperen.&lt;x4/&gt;Tip:&lt;x5/&gt; Typ ‘Duur’ in de zoekbalk!&lt;x6/&gt;Laat een raket opstijgen op de LED-matrix.&lt;x7/&gt;Tip:&lt;x8/&gt; Nu moet je denken als een animatieprofessional&lt;x9/&gt;-  in afzonderlijke beelden!&lt;x10/&gt;Zet de programmablokken in de juiste volgorde&lt;x11/&gt;en laat een aftelling van 3-2-1-0 weergeven.&lt;x12/&gt;a) Voeg achter elk getal een &lt;x13/&gt;pauze&lt;x14/&gt; in.&lt;x15/&gt;b) &lt;x16/&gt;Verleng&lt;x17/&gt; de pauzes door de waarde in milliseconden (ms) te verhogen.&lt;x18/&gt;c) &lt;x19/&gt;Sla&lt;x20/&gt; je programma op onder de naam „Raketlancering“.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>CO2-Sensor</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T113602Z" creationid="amando" creationdate="20260618T113602Z">
        <seg>CO₂-sensor</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Die LED-Matrix ist der &lt;x2/&gt;Bildschirm&lt;x3/&gt; des Calliope mini.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133402Z" creationid="amando" creationdate="20260618T133402Z">
        <seg>De LED-matrix is het &lt;x2/&gt;scherm&lt;x3/&gt; van de Calliope mini.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Einfach anschließen und den CO2 Gehalt, die Temperatur und die Luftfeuchtigkeit messen.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T113623Z" creationid="amando" creationdate="20260618T113623Z">
        <seg>Gewoon aansluiten en het CO₂-gehalte, de temperatuur en de luchtvochtigheid meten.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Erstelle dazu folgende Programme in MakeCode.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133230Z" creationid="amando" creationdate="20260618T133230Z">
        <seg>Maak hiervoor de volgende programma's in MakeCode.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Erstelle folgende Programme in MakeCode:</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133444Z" creationid="amando" creationdate="20260618T133444Z">
        <seg>Maak de volgende programma's in MakeCode:</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Es lassen sich Texte, Symbole und sogar Animationen anzeigen.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133410Z" creationid="amando" creationdate="20260618T133410Z">
        <seg>Er kunnen teksten, symbolen en zelfs animaties worden weergegeven.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Führe die einzelnen Schritte in der richtigen Reihenfolge aus und teste auf deinem Calliope mini.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133632Z" creationid="amando" creationdate="20260618T133632Z">
        <seg>Voer de afzonderlijke stappen in de juiste volgorde uit en test het resultaat op je Calliope mini.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Hier ist Platz für dein Struktogramm:</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T114340Z" creationid="amando" creationdate="20260618T114340Z">
        <seg>Hier is ruimte voor je structogram:</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Hier ist etwas durcheinander geraten.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133615Z" creationid="amando" creationdate="20260618T133615Z">
        <seg>Er is hier iets in de war geraakt.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Importiere die benötigten Programmblöcke:&lt;x2/&gt;CO2-Sensor-SCD40</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T113700Z" creationid="amando" creationdate="20260618T113700Z">
        <seg>Importeer de benodigde programmablokken:&lt;x2/&gt;CO2-sensor-SCD40</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>KENNENLERNEN</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133205Z" creationid="amando" creationdate="20260618T133205Z">
        <seg>KENNISMAKEN</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>LED-Matrix</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133354Z" creationid="amando" creationdate="20260618T133354Z">
        <seg>LED-matrix</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>LUFTQUALITÄT</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133107Z" creationid="amando" creationdate="20260618T133107Z">
        <seg>LUCHTKWALITEIT</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Luftqualität</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T114332Z" creationid="amando" creationdate="20260618T114332Z">
        <seg>Luchtkwaliteit</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Mit dem&lt;x1/&gt;Grove-Kabel wird der SCD40 über den Grove-Anschluss A0 mit dem Calliope mini verbunden.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T113648Z" creationid="amando" creationdate="20260618T113648Z">
        <seg>Met de&lt;x1/&gt;Grove-kabel wordt de SCD40 via de Grove-aansluiting A0 aangesloten op de Calliope mini.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Mit der CO2-Platine lassen sich drei unterschiedliche Werte messen.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T113618Z" creationid="amando" creationdate="20260618T113618Z">
        <seg>Met de CO2-printplaat kunnen drie verschillende waarden worden gemeten.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Raketenstart</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133607Z" creationid="amando" creationdate="20260618T133607Z">
        <seg>Raketlancering</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Relative Humidity&lt;x2/&gt;relative Luftfeuchtigkeit</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T114439Z" creationid="amando" creationdate="20260618T114315Z">
        <seg>Relative Humidity&lt;x2/&gt;relatieve luchtvochtigheid</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Schau dir die einzelnen Schritte zum Übertragen deines Programms auf den Calliope mini genau an und bringe sie in die richtige Reihenfolge.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133619Z" creationid="amando" creationdate="20260618T133619Z">
        <seg>Bekijk de afzonderlijke stappen voor het overzetten van je programma naar de Calliope mini goed en zet ze in de juiste volgorde.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Schleifen</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T114422Z" creationid="amando" creationdate="20260618T114422Z">
        <seg>Slijpen</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Schließe die Platine an.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T113643Z" creationid="amando" creationdate="20260618T113643Z">
        <seg>Sluit de printplaat aan.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Teste im Editor und beschreibe.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133218Z" creationid="amando" creationdate="20260618T133218Z">
        <seg>Test het in de editor en beschrijf het.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Testen im Simulator</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133329Z" creationid="amando" creationdate="20260618T133329Z">
        <seg>Testen in de simulator</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Tipp:&lt;x2/&gt; Die Farben der Blöcke geben dir einen Hinweis in welcher Kategorie du sie findest.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133337Z" creationid="amando" creationdate="20260618T133337Z">
        <seg>Tip:&lt;x2/&gt; De kleuren van de blokken geven je een indicatie in welke categorie je ze kunt vinden.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Vergiss nicht “Knopf A” und “Knopf B” zu drücken.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133636Z" creationid="amando" creationdate="20260618T133636Z">
        <seg>Vergeet niet op “knop A” en “knop B” te drukken.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Verwende die CO2-Platine um die Luftqualität zu messen.</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T113635Z" creationid="amando" creationdate="20260618T113635Z">
        <seg>Gebruik de CO2-printplaat om de luchtkwaliteit te meten.</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Was funktioniert noch nicht so gut?</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133136Z" creationid="amando" creationdate="20260618T133136Z">
        <seg>Wat werkt nog niet zo goed?</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Was funktioniert nocht nicht so gut?</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133132Z" creationid="amando" creationdate="20260618T133132Z">
        <seg>Wat werkt nog niet zo goed?</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Was funktioniert schon ziemlich gut?</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133124Z" creationid="amando" creationdate="20260618T133124Z">
        <seg>Wat werkt al redelijk goed?</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Welche Funktionen haben die einzelnen &lt;x1/&gt;Schaltflächen?</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133222Z" creationid="amando" creationdate="20260618T133214Z">
        <seg>Welke functies hebben de afzonderlijke &lt;x1/&gt;knoppen?</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Wichtige Blöcke:</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T114307Z" creationid="amando" creationdate="20260618T114307Z">
        <seg>Belangrijke onderdelen:</seg>
      </tuv>
    </tu>
    <tu>
      <tuv lang="de-DE">
        <seg>Woran hast du länger getüftelt?</seg>
      </tuv>
      <tuv lang="nl" changeid="amando" changedate="20260618T133116Z" creationid="amando" creationdate="20260618T133116Z">
        <seg>Waar heb je het langst aan zitten sleutelen?</seg>
      </tuv>
    </tu>
